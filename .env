# Same as root .env for DB and auth. Copy from root or symlink.
DATABASE_URL="mysql://root:@localhost:3306/pms"
NEXTAUTH_SECRET="your-secret-key-here"
PORT=4000

# Optional: allow CORS from frontend origin
CORS_ORIGIN=http://localhost:3000

# INITIAL ADMIN BOOTSTRAP VARIABLES
# Enable to idempotently create an admin user on seed launch or restart
BOOTSTRAP_ADMIN=false 
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=admin@qeematech.net
ADMIN_BOOTSTRAP_PASSWORD=SuperStrongP@ssw0rd!123@@

# SECURE YOUR OPERATION: Immediately disable BOOTSTRAP_ADMIN=false after seed!
