# Database (required for login and API)
# Must match the DB you ran prisma/seed.js against
DATABASE_URL="mysql://root:@localhost:3306/pms"

# Server
PORT=4000

# Browser CORS: env origins are merged with built-in defaults (localhost + qeemasupport.site).
# Add more production domains: CORS_ORIGINS=https://app.example.com
# Use only your list (no defaults): CORS_STRICT=1 and CORS_ORIGINS=https://app.example.com
# CORS_ORIGINS=https://qeemasupport.site

# JWT secret for login and protected routes. If unset, backend uses fallback "your-secret-key" (dev only).
# NEXTAUTH_SECRET=your-secret-key-here

# Rate limit: max requests per 15 minutes (per IP). Default: 2000 global, 500 for /api/v1.
# If you see 429 Too Many Requests, increase these or set RATE_LIMIT_MAX_API=2000
# RATE_LIMIT_MAX_GLOBAL=2000
# RATE_LIMIT_MAX_API=500

# INITIAL ADMIN BOOTSTRAP VARIABLES
# Enable to idempotently create an admin user on seed launch or restart
# BOOTSTRAP_ADMIN=true
# ADMIN_BOOTSTRAP_USERNAME=admin
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# ADMIN_BOOTSTRAP_PASSWORD=StrongPasswordHere123
# Remember to remove/disable these strings in a production environment immediately after seed!
