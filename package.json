{
  "name": "@pms/backend",
  "version": "1.0.0",
  "private": true,
  "description": "PMS backend API service (Phase 2)",
  "main": "src/server.js",
  "scripts": {
    "test": "npm run test:kpis",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "deploy:db": "node scripts/prisma-production-guard.js migrate deploy",
    "prisma:prod": "node scripts/prisma-production-guard.js",
    "prisma:seed": "node prisma/seed.js",
    "seed:dev:reset": "node prisma/seed.js",
    "seed:prod:safe": "node prisma/seed-prod-safe.js",
    "test:api": "node scripts/test-api.js",
    "test:kpis": "node src/tests/todaysFocusReportKpis.runner.js",
    "script:init-rbac": "node scripts/initialize-rbac.js",
    "script:list-users": "node scripts/list-users.js",
    "script:verify-db": "node scripts/verify-db-counts.js",
    "script:create-db": "node scripts/create-database.js",
    "seed": "node prisma/seed.js",
    "script:check-permissions": "node scripts/check-permissions.js",
    "script:ensure-report-permissions": "node scripts/ensure-report-permissions.js",
    "script:audit-rbac-bypasses": "node scripts/audit-rbac-bypasses.js",
    "test:change-password": "node scripts/test-change-password.js",
    "script:validate-seed-safety": "node scripts/validate-seed-safety.js",
    "script:export-data": "node scripts/export-business-data.js",
    "script:db:backup-migrate-restore": "node scripts/backup-migrate-restore.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^5.10.2",
    "@sentry/node": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-prometheus-middleware": "^1.2.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "mysql2": "^3.22.0",
    "prisma": "^5.10.2",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=18"
  }
}
